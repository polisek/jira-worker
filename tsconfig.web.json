{
    "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
    "include": ["src/renderer/src/**/*", "src/preload/index.d.ts"],
    "compilerOptions": {
        "composite": true,
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "paths": {
            "@renderer/*": ["src/renderer/src/*"]
        },
        "allowArbitraryExtensions": true
    }
}
